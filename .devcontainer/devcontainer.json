{
	"name": "ROS 2 Devcontainer (CPU-only)",
	"dockerComposeFile": [
		"compose.yaml"
	],
	"service": "develop",
	"workspaceFolder": "/workspace",
	"remoteUser": "root",

	"forwardPorts": [
		"vnc:5801"
	],
	"portsAttributes": {
		"vnc:5801": {
			"label": "novnc"
		}
	},

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"GitHub.vscode-pull-request-github",
				"ms-vscode.cpptools",
				"JaehyunShim.vscode-ros2",
				"nonanonno.vscode-ros2",
				"deitry.colcon-helper",
				"github.vscode-github-actions"
			]
		}
	},
	"hostRequirements": {
		"cpus": 1,
		"memory": "2gb"
	}
}
